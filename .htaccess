# =====================================================================
# PHP Hata Görüntüleme — Canlı sunucuda ekrana yansımasın, loga gitsin
# =====================================================================
<IfModule mod_php.c>
  php_flag  display_errors Off
  php_flag  display_startup_errors Off
  php_value error_reporting 32767
  php_flag  log_errors On
</IfModule>

# =====================================================================
# SEO Dostu URL — Tüm istekleri router.php'ye yönlendir (gerçek dosya/klasör değilse)
# =====================================================================
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # www → non-www (kalıcı 301)
  RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
  RewriteRule ^ https://%1%{REQUEST_URI} [R=301,L]

  # HTTP → HTTPS (kalıcı 301)
  RewriteCond %{HTTPS} !=on
  RewriteCond %{HTTP:X-Forwarded-Proto} !=https
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

  # Trailing slash'ı kaldır (canonical)
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_URI} ^(.+)/$
  RewriteRule ^ %1 [R=301,L]

  # /robots.txt → robots.php (dinamik — çok domain desteği)
  RewriteRule ^robots\.txt$ robots.php [L]

  # /sitemap.xml → sitemap.php (dinamik — çok domain desteği)
  RewriteRule ^sitemap\.xml$ sitemap.php [L]

  # /api/* → api/index.php (LLM/agent JSON uç noktaları)
  RewriteRule ^api(/.*)?$ api/index.php [QSA,L]

  # Gerçek dosyalar (style.css, .webp vs.) ve klasörler doğrudan servis edilir
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  # Geri kalan tüm istekler router.php'ye gider
  RewriteRule ^(.*)$ router.php [QSA,L]
</IfModule>

# Hassas dosyaları doğrudan servis etmeyi engelle (kaynak kod, yedek, dump)
<FilesMatch "\.(sql|md|log|env|htaccess|zip|tar|gz|tgz|7z|rar|bak|backup|swp|json|lock|composer)$">
  Require all denied
</FilesMatch>
# CSS minify yedekleri (.src.css) — sadece geliştirme içindir, web'e açma
<FilesMatch "\.src\.css$">
  Require all denied
</FilesMatch>
# Composer / Git / Node iz dosyaları
<FilesMatch "^(composer\.(json|lock)|package(-lock)?\.json|\.gitignore|\.gitattributes|\.editorconfig|\.eslintrc.*|README.*|CHANGELOG.*)$">
  Require all denied
</FilesMatch>

# Dahili dizinleri tamamen gizle (kaynak kod, yedek, vendor, node_modules, vs.)
<IfModule mod_rewrite.c>
  RewriteRule ^(config|sql|core|models|controllers|vendor|yedek|node_modules|\.git|\.agents|\.idea|\.vscode|tests|test)(/.*)?$ - [F,L]
</IfModule>
# WordPress / büyük XML dump'larını engelle (sitemap.xml zaten yukarıda rewrite ediliyor)
<FilesMatch "(WordPress|wp-)\.xml$">
  Require all denied
</FilesMatch>
# uploads/import içindeki XML'lere doğrudan erişim yok
<IfModule mod_rewrite.c>
  RewriteRule ^uploads/import/.*$ - [F,L]
</IfModule>

# Performans: yaygın varlıkları tarayıcıda cache'le (URL'lerde ?v= sürüm parametresi var)
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/webp           "access plus 1 year"
  ExpiresByType image/jpeg           "access plus 1 year"
  ExpiresByType image/jpg            "access plus 1 year"
  ExpiresByType image/png            "access plus 1 year"
  ExpiresByType image/gif            "access plus 1 year"
  ExpiresByType image/svg+xml        "access plus 6 months"
  ExpiresByType image/x-icon         "access plus 1 year"
  ExpiresByType text/css             "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType text/javascript      "access plus 1 year"
  ExpiresByType font/woff            "access plus 1 year"
  ExpiresByType font/woff2           "access plus 1 year"
  ExpiresByType application/font-woff2 "access plus 1 year"
  ExpiresByType application/x-font-ttf "access plus 1 year"
  ExpiresByType text/html            "access plus 0 seconds"
</IfModule>

# Cache-Control + immutable (versiyonlu varlıklar için)
<IfModule mod_headers.c>
  <FilesMatch "\.(css|js|woff2?|ttf|otf|webp|jpg|jpeg|png|gif|ico|svg)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.(html|php)$">
    Header set Cache-Control "public, max-age=300, stale-while-revalidate=3600"
  </FilesMatch>
</IfModule>

# Gzip / Deflate — geniş kapsam
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript
  AddOutputFilterByType DEFLATE application/javascript application/x-javascript application/json
  AddOutputFilterByType DEFLATE application/xml application/rss+xml application/atom+xml
  AddOutputFilterByType DEFLATE image/svg+xml font/ttf font/otf application/x-font-ttf
</IfModule>

# Brotli (varsa daha iyi sıkıştırır)
<IfModule mod_brotli.c>
  AddOutputFilterByType BROTLI_COMPRESS text/html text/css application/javascript application/json image/svg+xml
</IfModule>

# CSP (Apache override — PHP'nin gönderdiği eski başlıkları ezer)
<IfModule mod_headers.c>
  Header always set Content-Security-Policy "default-src 'self' https:; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://www.youtube.com https://www.youtube-nocookie.com https://static.iyzipay.com https://sandbox-static.iyzipay.com https://www.googletagmanager.com https://www.google-analytics.com https://ssl.google-analytics.com https://connect.facebook.net https://www.clarity.ms https://*.clarity.ms; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdn.jsdelivr.net https://static.iyzipay.com https://sandbox-static.iyzipay.com; font-src 'self' https://fonts.gstatic.com data: https://cdn.jsdelivr.net https://static.iyzipay.com https://sandbox-static.iyzipay.com; img-src 'self' data: https:; connect-src 'self' https:; frame-src https://www.youtube.com https://www.youtube-nocookie.com https://player.vimeo.com https://static.iyzipay.com https://sandbox-static.iyzipay.com https://www.iyzico.com https://sandbox.iyzipay.com https://www.google.com https://www.googletagmanager.com https://td.doubleclick.net; frame-ancestors 'self'"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set X-Content-Type-Options "nosniff"
  # HSTS — HTTPS'te kal (1 yıl, alt-domain'ler dahil)
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
  # Iframe gömülmesi engelle (clickjacking koruması)
  Header always set X-Frame-Options "SAMEORIGIN"
  # Tarayıcı izinleri — varsayılan kapalı
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=(self), interest-cohort=()"
  # Cross-origin izolasyonu
  Header always set Cross-Origin-Opener-Policy "same-origin"
  Header always set X-XSS-Protection "1; mode=block"
  # Server signature gizle
  Header always unset X-Powered-By
  Header always unset Server
</IfModule>
