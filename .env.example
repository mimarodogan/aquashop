# AquaShop — Ortam Değişkenleri (K-6 — DB kimlik bilgileri repo dışında)
#
# KULLANIM:
#   1) Bu dosyayı sunucuda '.env' olarak kopyalayın:    cp .env.example .env
#   2) Aşağıdaki değerleri gerçek hosting değerleriyle güncelleyin.
#   3) .env dosyasına 644 permission verin (chmod 644 .env).
#   4) config/db.php otomatik olarak .env'i okur.
#
# GÜVENLİK:
#   - .env dosyası kök .htaccess tarafından bloklanır (web'den erişilemez).
#   - Bu dosyayı git'e commit ETMEYİN; .gitignore'a alın.
#   - Şifrelerinizi rotasyona alın — eski hardcoded şifreyi cPanel'den değiştirin.

DB_HOST=127.0.0.1
DB_NAME=aqua_yourdb
DB_USER=aqua_youruser
DB_PASS=ROTATE_THIS_PASSWORD_IMMEDIATELY
DB_CHARSET=utf8mb4

# Ortam: production | development
# - development → display_errors=1, stack trace görünür
# - production  → display_errors=0, kullanıcıya generic mesaj
APP_ENV=production

# Güvenli proxy IP'leri (Cloudflare, hosting reverse proxy vb.).
# Boş bırakılırsa sadece REMOTE_ADDR güvenilir kabul edilir (en sıkı mod).
# Birden fazla IP virgülle ayır.
# Örnek: TRUSTED_PROXIES=127.0.0.1,10.0.0.0/8
TRUSTED_PROXIES=
